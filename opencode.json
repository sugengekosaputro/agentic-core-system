{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "bash": {
      "git add*": "allow",
      "git blame*": "allow",
      "git branch*": "ask",
      "git checkout*": "ask",
      "git clean*": "ask",
      "git commit*": "ask",
      "git config --get*": "allow",
      "git config --list*": "allow",
      "git describe*": "allow",
      "git diff*": "allow",
      "git fetch*": "ask",
      "git grep*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git merge*": "ask",
      "git merge-base*": "allow",
      "git mv*": "ask",
      "git pull*": "ask",
      "git push*": "ask",
      "git rebase*": "ask",
      "git remote -v*": "allow",
      "git remote add*": "ask",
      "git remote prune*": "ask",
      "git remote remove*": "ask",
      "git remote rename*": "ask",
      "git remote set-url*": "ask",
      "git reset*": "ask",
      "git restore*": "ask",
      "git rev-list*": "allow",
      "git rev-parse*": "allow",
      "git rm*": "ask",
      "git show*": "allow",
      "git status*": "allow",
      "git switch*": "ask",
      "git tag*": "ask"
    }
  }
}
