{
  "schemaVersion": 1,
  "description": "Canonical agent permission policy. Git inspection and staging are routine; history, remote, branch-changing, and destructive operations require confirmation.",
  "rules": {
    "allow": [
      ["git", "status"],
      ["git", "diff"],
      ["git", "log"],
      ["git", "show"],
      ["git", "ls-files"],
      ["git", "rev-parse"],
      ["git", "rev-list"],
      ["git", "merge-base"],
      ["git", "describe"],
      ["git", "config", "--get"],
      ["git", "config", "--list"],
      ["git", "remote", "-v"],
      ["git", "blame"],
      ["git", "grep"],
      ["git", "add"]
    ],
    "prompt": [
      ["git", "commit"],
      ["git", "push"],
      ["git", "pull"],
      ["git", "fetch"],
      ["git", "merge"],
      ["git", "rebase"],
      ["git", "reset"],
      ["git", "checkout"],
      ["git", "switch"],
      ["git", "branch"],
      ["git", "tag"],
      ["git", "clean"],
      ["git", "restore"],
      ["git", "remote", "add"],
      ["git", "remote", "remove"],
      ["git", "remote", "rename"],
      ["git", "remote", "set-url"],
      ["git", "remote", "prune"],
      ["git", "rm"],
      ["git", "mv"]
    ],
    "deny": []
  }
}
