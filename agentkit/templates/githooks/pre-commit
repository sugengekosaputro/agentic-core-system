#!/usr/bin/env sh
# Agent-context safety gate (managed by agentkit-core; do not edit).
#
# Runs at the git layer, so it applies no matter which provider/agent creates the
# commit. It guarantees generated provider adapters and skill symlinks stay in
# sync with the canonical sources in `.agents/**` and `AGENTS.md`. Checks only;
# it never rewrites files.
set -e

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if command -v agentkit >/dev/null 2>&1; then
  CHECK="agentkit validate"
elif command -v python3 >/dev/null 2>&1; then
  CHECK="python3 -m agentkit.cli validate"
else
  echo "pre-commit BLOCKED: neither 'agentkit' nor python3 found; cannot verify agent context." >&2
  echo "Install agentkit (pipx install agentkit-core) or bypass once with 'git commit --no-verify'." >&2
  exit 1
fi

echo "pre-commit: verifying agent context is in sync..."
if ! $CHECK; then
  echo "" >&2
  echo "pre-commit BLOCKED: agent context out of sync or invalid." >&2
  echo "Fix: run 'agentkit sync', then 'git add -A && git commit'." >&2
  exit 1
fi

echo "pre-commit: agent context OK."
