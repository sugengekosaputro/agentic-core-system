{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentkit.dev/schemas/project.schema.json",
  "title": "agentkit project.json",
  "type": "object",
  "required": ["schemaVersion", "name", "skills"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "language": { "type": "string" },
    "framework": { "type": "string" },
    "buildTool": { "type": "string" },
    "commands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "kit": {
      "type": "object",
      "properties": {
        "core": { "type": "string" },
        "presets": { "type": "array" }
      }
    },
    "skills": {
      "type": "object",
      "required": ["core", "virtual-assistant", "stack"],
      "properties": {
        "core": { "type": "array", "items": { "type": "string" } },
        "virtual-assistant": { "type": "array", "items": { "type": "string" } },
        "stack": { "type": "array", "items": { "type": "string" } }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "scope": { "enum": ["workspace", "agent", "both"] }
      }
    },
    "kitManaged": { "type": "array", "items": { "type": "string" } }
  }
}
