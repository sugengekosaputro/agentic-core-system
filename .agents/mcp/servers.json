{
  "schemaVersion": 1,
  "description": "Base MCP server metadata shipped by agentkit-core. Store environment variable names only; keep values in .env.mcp. Presets add stack-specific servers (e.g. postgres, github).",
  "servers": [
    {
      "name": "context7",
      "enabledByDefault": true,
      "required": false,
      "transport": "http",
      "url": "https://mcp.context7.com/mcp",
      "approval": "auto",
      "envVars": []
    },
    {
      "name": "filesystem",
      "enabledByDefault": false,
      "required": false,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "${REPO_ROOT}"
      ],
      "approval": "prompt",
      "toolApprovals": {
        "read_file": "auto",
        "read_text_file": "auto",
        "read_media_file": "auto",
        "read_multiple_files": "auto",
        "list_allowed_directories": "auto",
        "list_directory": "auto",
        "list_directory_with_sizes": "auto",
        "directory_tree": "auto",
        "search_files": "auto",
        "get_file_info": "auto",
        "write_file": "prompt",
        "edit_file": "prompt",
        "create_directory": "prompt",
        "move_file": "prompt"
      },
      "envVars": []
    }
  ]
}
